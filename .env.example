# -------------------------------------------------------
# Keystatic CMS – GitHub OAuth (required in production)
# -------------------------------------------------------
# 1. Go to https://github.com/settings/developers → "New OAuth App"
# 2. Application name: GIO.I.A CMS
# 3. Homepage URL: https://your-domain.vercel.app
# 4. Authorization callback URL: https://your-domain.vercel.app/api/keystatic/github/oauth/callback
# 5. Copy the Client ID and generate a Client Secret

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# Random secret string (min 32 chars) used for session encryption.
# Generate one with: openssl rand -base64 32
KEYSTATIC_SECRET=
