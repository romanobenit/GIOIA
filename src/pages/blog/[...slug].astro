---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date.toLocaleDateString('it-IT', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categoryColors: Record<string, string> = {
  Notizie: 'bg-blue-100 text-blue-800',
  Eventi: 'bg-purple-100 text-purple-800',
  Storie: 'bg-rose-100 text-rose-800',
};
---

<Layout title={post.data.title} description={post.data.excerpt}>
  <article>
    <!-- Cover image -->
    <div class="relative h-64 md:h-96 bg-amber-100 overflow-hidden">
      <img
        src={post.data.coverImage}
        alt={`Immagine di copertina: ${post.data.title}`}
        class="w-full h-full object-cover"
        onerror="this.src='/images/blog/placeholder.svg'"
      />
    </div>

    <!-- Article header -->
    <header class="max-w-3xl mx-auto px-4 pt-10 pb-4">
      <div class="flex items-center gap-3 mb-4">
        <span class:list={['text-xs font-bold uppercase tracking-wide px-2 py-1 rounded-full', categoryColors[post.data.category] ?? 'bg-gray-100 text-gray-700']}>
          {post.data.category}
        </span>
        <time datetime={post.data.date.toISOString()} class="text-sm text-gray-500">
          {formattedDate}
        </time>
        <span class="text-sm text-gray-400">di {post.data.author}</span>
      </div>
      <h1 class="text-gray-900">{post.data.title}</h1>
      <p class="text-xl text-gray-500 mt-3 leading-relaxed">{post.data.excerpt}</p>
    </header>

    <!-- Article body -->
    <div class="max-w-3xl mx-auto px-4 pb-16 prose prose-gray prose-lg">
      <Content />
    </div>
  </article>

  <!-- Back link -->
  <div class="max-w-3xl mx-auto px-4 pb-12">
    <a href="/blog" class="text-gioia-yellow-dark font-semibold hover:underline">
      ← Torna al blog
    </a>
  </div>
</Layout>
