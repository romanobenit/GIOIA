---
import Layout from '../layouts/Layout.astro';

const INDIRIZZO = '[DA COMPILARE]';
const TELEFONO = '[DA COMPILARE]';
const EMAIL = '[DA COMPILARE]';
const FORMSPREE_ENDPOINT = '[DA COMPILARE]';
const COORDINATE_MAPPA = '[DA COMPILARE]';
// Google Maps embed example: https://maps.google.com/maps?q=LAT,LNG&output=embed
---

<Layout title="Contatti" description="Contatta GIO.I.A: indirizzo, telefono, email e modulo di contatto.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-amber-50 to-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-gioia-yellow-dark mb-4">Contatti</h1>
      <p class="text-xl text-gray-600">
        Siamo qui per te. Scrivici, chiamaci o vieni a trovarci!
      </p>
    </div>
  </section>

  <section class="section">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact info + map -->
      <div class="space-y-8">
        <div>
          <h2 class="text-gray-900 mb-6">Come raggiungerci</h2>
          <ul class="space-y-4 text-gray-700">
            <li class="flex items-start gap-3">
              <span class="text-2xl" aria-hidden="true">📍</span>
              <div>
                <p class="font-semibold">Indirizzo</p>
                <p>{INDIRIZZO}</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-2xl" aria-hidden="true">📞</span>
              <div>
                <p class="font-semibold">Telefono</p>
                {TELEFONO !== '[DA COMPILARE]'
                  ? <a href={`tel:${TELEFONO}`} class="text-gioia-yellow-dark hover:underline">{TELEFONO}</a>
                  : <p>{TELEFONO}</p>
                }
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-2xl" aria-hidden="true">✉️</span>
              <div>
                <p class="font-semibold">Email</p>
                {EMAIL !== '[DA COMPILARE]'
                  ? <a href={`mailto:${EMAIL}`} class="text-gioia-yellow-dark hover:underline">{EMAIL}</a>
                  : <p>{EMAIL}</p>
                }
              </div>
            </li>
          </ul>
        </div>

        <!-- Map -->
        <div class="rounded-2xl overflow-hidden border border-gray-200 h-64 bg-gray-100 flex items-center justify-center">
          {COORDINATE_MAPPA !== '[DA COMPILARE]'
            ? (
              <iframe
                title="Mappa posizione GIO.I.A"
                src={`https://maps.google.com/maps?q=${COORDINATE_MAPPA}&output=embed`}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            )
            : (
              <p class="text-gray-400 text-sm italic">Mappa: [DA COMPILARE coordinate]</p>
            )
          }
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <h2 class="text-gray-900 mb-6">Inviaci un messaggio</h2>
        {FORMSPREE_ENDPOINT !== '[DA COMPILARE]'
          ? (
            <form
              action={FORMSPREE_ENDPOINT}
              method="POST"
              class="space-y-5"
              novalidate
            >
              <div>
                <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">
                  Nome e cognome <span aria-hidden="true" class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gioia-yellow focus:border-transparent"
                  placeholder="Mario Rossi"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">
                  Email <span aria-hidden="true" class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gioia-yellow focus:border-transparent"
                  placeholder="mario@esempio.it"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">
                  Messaggio <span aria-hidden="true" class="text-red-500">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gioia-yellow focus:border-transparent resize-none"
                  placeholder="Scrivi qui il tuo messaggio..."
                ></textarea>
              </div>
              <button type="submit" class="btn-primary w-full text-center">
                Invia messaggio
              </button>
            </form>
          )
          : (
            <div class="bg-amber-50 rounded-2xl p-8 text-center text-gray-500">
              <p class="text-3xl mb-3" aria-hidden="true">📬</p>
              <p class="font-semibold text-gray-700 mb-2">Form contatti</p>
              <p class="text-sm italic">
                [DA COMPILARE – inserire l'endpoint Formspree per attivare il form]
              </p>
              <p class="text-sm mt-4">
                Nel frattempo puoi scriverci a: <strong>{EMAIL}</strong>
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>
</Layout>
