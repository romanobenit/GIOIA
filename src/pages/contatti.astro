---
import Layout from '../layouts/Layout.astro';

const SEDE_OPERATIVA   = 'Via Farnesina 53, Roma';
const SEDE_LEGALE      = 'V. M. Clementi, 7/F – 01036 Nepi (VT)';
const CELLULARE_1      = '371 517 6801';
const CELLULARE_2      = '334 280 4113';
const EMAIL            = 'gioia-aps@libero.it';
const FORMSPREE_ENDPOINT = '[DA COMPILARE]';
// Mappa centrata sulla sede operativa (Via Farnesina 53, Roma)
const INDIRIZZO_MAPPA  = encodeURIComponent('Via Farnesina 53, Roma');
---

<Layout title="Contatti" description="Contatta GIO.I.A: indirizzo, telefono, email e modulo di contatto.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-amber-50 to-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-gioia-yellow-dark mb-4">Contatti</h1>
      <p class="text-xl text-gray-600">
        Siamo qui per te. Scrivici, chiamaci o vieni a trovarci!
      </p>
    </div>
  </section>

  <section class="section">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact info + map -->
      <div class="space-y-8">
        <div>
          <h2 class="text-gray-900 mb-6">Come raggiungerci</h2>
          <ul class="space-y-5 text-gray-700">

            <!-- Sede operativa -->
            <li class="flex items-start gap-3">
              <span class="text-2xl" aria-hidden="true">📍</span>
              <div>
                <p class="font-semibold">Sede operativa</p>
                <p>{SEDE_OPERATIVA}</p>
              </div>
            </li>

            <!-- Sede legale -->
            <li class="flex items-start gap-3">
              <span class="text-2xl" aria-hidden="true">🏛️</span>
              <div>
                <p class="font-semibold">Sede legale</p>
                <p>{SEDE_LEGALE}</p>
              </div>
            </li>

            <!-- Cellulari -->
            <li class="flex items-start gap-3">
              <span class="text-2xl" aria-hidden="true">📱</span>
              <div>
                <p class="font-semibold">Cellulare</p>
                <p>
                  <a href={`tel:+39${CELLULARE_1.replace(/\s/g,'')}`} class="text-gioia-yellow-dark hover:underline">
                    {CELLULARE_1}
                  </a>
                </p>
                <p>
                  <a href={`tel:+39${CELLULARE_2.replace(/\s/g,'')}`} class="text-gioia-yellow-dark hover:underline">
                    {CELLULARE_2}
                  </a>
                </p>
              </div>
            </li>

            <!-- Email -->
            <li class="flex items-start gap-3">
              <span class="text-2xl" aria-hidden="true">✉️</span>
              <div>
                <p class="font-semibold">Email</p>
                <a href={`mailto:${EMAIL}`} class="text-gioia-yellow-dark hover:underline">
                  {EMAIL}
                </a>
              </div>
            </li>
          </ul>
        </div>

        <!-- Map – sede operativa Via Farnesina 53, Roma -->
        <div class="rounded-2xl overflow-hidden border border-gray-200 h-64">
          <iframe
            title="Mappa sede operativa GIO.I.A – Via Farnesina 53, Roma"
            src={`https://maps.google.com/maps?q=${INDIRIZZO_MAPPA}&output=embed`}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <h2 class="text-gray-900 mb-6">Inviaci un messaggio</h2>
        {FORMSPREE_ENDPOINT !== '[DA COMPILARE]'
          ? (
            <form action={FORMSPREE_ENDPOINT} method="POST" class="space-y-5" novalidate>
              <div>
                <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">
                  Nome e cognome <span aria-hidden="true" class="text-red-500">*</span>
                </label>
                <input
                  type="text" id="name" name="name" required autocomplete="name"
                  class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gioia-yellow focus:border-transparent"
                  placeholder="Mario Rossi"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">
                  Email <span aria-hidden="true" class="text-red-500">*</span>
                </label>
                <input
                  type="email" id="email" name="email" required autocomplete="email"
                  class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gioia-yellow focus:border-transparent"
                  placeholder="mario@esempio.it"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">
                  Messaggio <span aria-hidden="true" class="text-red-500">*</span>
                </label>
                <textarea
                  id="message" name="message" required rows="5"
                  class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gioia-yellow focus:border-transparent resize-none"
                  placeholder="Scrivi qui il tuo messaggio..."
                ></textarea>
              </div>
              <button type="submit" class="btn-primary w-full text-center">
                Invia messaggio
              </button>
            </form>
          )
          : (
            <div class="bg-amber-50 rounded-2xl p-8 text-center text-gray-500">
              <p class="text-3xl mb-3" aria-hidden="true">📬</p>
              <p class="font-semibold text-gray-700 mb-2">Scrivici direttamente</p>
              <p class="text-sm mb-4">
                Inviaci una mail a{' '}
                <a href={`mailto:${EMAIL}`} class="text-gioia-yellow-dark font-semibold hover:underline">
                  {EMAIL}
                </a>
              </p>
              <p class="text-sm text-gray-400 italic">
                [DA COMPILARE – inserire endpoint Formspree per attivare il form online]
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>
</Layout>
