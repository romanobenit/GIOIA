---
import Layout from '../layouts/Layout.astro';
import ActivityCard from '../components/ActivityCard.astro';

// "Tirocini formativi" e "Formazione pratica" sono stati rimossi.
// "Accompagnamento al lavoro" e "Laboratorio di orientamento" sono al condizionale
// in quanto obiettivi/missioni future.
const activitiesLavorativa = [
  {
    title: 'Laboratorio di orientamento',
    description:
      'Vorremmo sviluppare sessioni di gruppo per esplorare interessi, scoprire punti di forza e costruire un progetto professionale su misura — una delle nostre priorità future.',
    icon: '🧭',
  },
  {
    title: 'Accompagnamento al lavoro',
    description:
      'Potremmo offrire supporto individuale nelle prime fasi lavorative: affiancamento in azienda, monitoraggio e mediazione con i datori di lavoro — quando le condizioni normative lo consentiranno.',
    icon: '🤝',
  },
];

const activitiesRicreativa = [
  {
    title: 'Uscite sociali',
    description:
      'Gite, visite culturali, cinema, sagre e passeggiate per esplorare il territorio e vivere esperienze in gruppo.',
    icon: '🚌',
  },
  {
    title: 'Laboratori creativi',
    description:
      'Attività artistiche, musicali e manuali che stimolano la creatività e favoriscono l\'espressione personale.',
    icon: '🎨',
  },
  {
    title: 'Sport e movimento',
    description:
      'Attività fisiche adattate, giochi di squadra e avvicinamento allo sport per il benessere psicofisico.',
    icon: '⚽',
  },
  {
    title: 'Feste ed eventi',
    description:
      'Momenti di celebrazione, ricorrenze e incontri comunitari per rafforzare i legami e condividere la gioia.',
    icon: '🎉',
  },
];
---

<Layout title="Attività" description="Scopri tutte le attività di GIO.I.A: percorsi lavorativi, laboratori creativi, sport ed eventi sociali.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-amber-50 to-emerald-50 py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-gioia-yellow-dark mb-4">Le nostre attività</h1>
      <p class="text-xl text-gray-600 leading-relaxed">
        Due aree di intervento, un unico obiettivo: costruire opportunità di
        crescita, autonomia e felicità per ogni persona.
      </p>
    </div>
  </section>

  <!-- Workforce inclusion -->
  <section class="section">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl" aria-hidden="true">💼</span>
      <h2 class="text-gray-900">Inclusione lavorativa</h2>
    </div>

    <!-- Testo introduttivo aggiornato -->
    <div class="mb-8 max-w-2xl space-y-4">
      <p class="text-gray-600 leading-relaxed">
        Crediamo che il lavoro sia un potente strumento di autonomia e dignità.
        <strong class="text-gray-800">Autodeterminazione.</strong>
      </p>

      <p class="text-gray-700 leading-relaxed font-medium">
        Lo scopo che ci accomuna è sensibilizzare e accendere un faro sulle leggi in vigore,
        il cui <strong>METODO</strong> per l'inserimento lavorativo risulta essere
        <strong>INIQUO e frustrante</strong> per le persone con disabilità intellettiva,
        seppur con grande volontà e capacità lavorativa.
      </p>

      <!-- Puntini verdi – contenuto dalla foto [DA COMPILARE con i punti reali] -->
      <ul class="space-y-2 pt-1">
        {[
          '[DA COMPILARE – punto 1]',
          '[DA COMPILARE – punto 2]',
          '[DA COMPILARE – punto 3]',
          '[DA COMPILARE – punto 4]',
        ].map((punto) => (
          <li class="flex items-start gap-2 text-gray-600 leading-relaxed">
            <span class="mt-1.5 w-2.5 h-2.5 rounded-full bg-emerald-500 flex-shrink-0" aria-hidden="true"></span>
            <span>{punto}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Attività al condizionale (missioni future) -->
    <div class="mb-3">
      <p class="text-sm font-semibold text-amber-700 uppercase tracking-wide">Missioni future</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl">
      {activitiesLavorativa.map((a) => (
        <ActivityCard title={a.title} description={a.description} icon={a.icon} category="lavorativa" />
      ))}
    </div>
  </section>

  <!-- Socio-recreational -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-3xl" aria-hidden="true">🌈</span>
        <h2 class="text-gray-900">Attività socio-ricreative</h2>
      </div>
      <p class="text-gray-600 mb-8 max-w-2xl leading-relaxed">
        La vita è fatta anche di svago, cultura e amicizia. Le nostre attività
        ricreative sono spazi di libertà, relazione e benessere condiviso.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {activitiesRicreativa.map((a) => (
          <ActivityCard title={a.title} description={a.description} icon={a.icon} category="ricreativa" />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center">
    <h2 class="text-gray-900 mb-4">Vuoi partecipare?</h2>
    <p class="text-gray-600 mb-8 max-w-xl mx-auto leading-relaxed">
      Contattaci per sapere come iscriversi alle attività o per ricevere
      informazioni personalizzate per te o per la tua famiglia.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contatti" class="btn-primary">Contattaci</a>
      <a href="/donazioni" class="btn-outline">Sostienici</a>
    </div>
  </section>
</Layout>
