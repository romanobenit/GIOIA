---
import Layout from '../layouts/Layout.astro';
import ActivityCard from '../components/ActivityCard.astro';
---

<Layout title="Home" description="GIO.I.A – Insieme, con gioia. APS per l'inclusione lavorativa e le attività socio-ricreative.">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-amber-50 via-white to-emerald-50 py-20 px-4 overflow-hidden">

    <!-- Logo associazione in sottofondo (watermark) -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" aria-hidden="true">
      <img
        src="/images/logo.png"
        alt=""
        class="w-[28rem] max-w-full opacity-[0.06] object-contain"
      />
    </div>

    <!-- QR code – in alto a destra -->
    <div class="absolute top-4 right-4 z-10">
      <div class="w-24 h-24 bg-white border-2 border-gray-200 rounded-xl shadow-md flex flex-col items-center justify-center gap-1 p-2">
        <!-- Sostituire con <img src="/images/qr-code.png" alt="QR code GIO.I.A" class="w-full h-full object-contain" /> quando disponibile -->
        <svg viewBox="0 0 60 60" class="w-14 h-14 opacity-30" aria-hidden="true">
          <rect x="2" y="2" width="24" height="24" fill="none" stroke="currentColor" stroke-width="3"/>
          <rect x="8" y="8" width="12" height="12" fill="currentColor"/>
          <rect x="34" y="2" width="24" height="24" fill="none" stroke="currentColor" stroke-width="3"/>
          <rect x="40" y="8" width="12" height="12" fill="currentColor"/>
          <rect x="2" y="34" width="24" height="24" fill="none" stroke="currentColor" stroke-width="3"/>
          <rect x="8" y="40" width="12" height="12" fill="currentColor"/>
          <rect x="34" y="34" width="6" height="6" fill="currentColor"/>
          <rect x="44" y="34" width="6" height="6" fill="currentColor"/>
          <rect x="34" y="44" width="6" height="6" fill="currentColor"/>
          <rect x="44" y="44" width="6" height="6" fill="currentColor"/>
          <rect x="54" y="34" width="6" height="6" fill="currentColor"/>
          <rect x="34" y="54" width="6" height="6" fill="currentColor"/>
          <rect x="54" y="54" width="6" height="6" fill="currentColor"/>
        </svg>
        <span class="text-[9px] text-gray-400 font-semibold text-center leading-tight">[DA COMPILARE]</span>
      </div>
    </div>

    <!-- Contenuto principale -->
    <div class="max-w-4xl mx-auto text-center relative z-10">

      <!-- Logo associazione in alto al centro -->
      <div class="flex justify-center mb-6">
        <img
          src="/images/logo.png"
          alt="GIO.I.A APS"
          class="h-40 md:h-48 w-auto object-contain drop-shadow-md"
          width="320"
          height="192"
        />
      </div>

      <h1 class="font-black text-gioia-yellow-dark mb-4">
        GIO.I.A
      </h1>
      <p class="text-2xl md:text-3xl font-bold text-gray-700 mb-6">
        Insieme, con gioia.
      </p>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-10 leading-relaxed">
        Siamo un'associazione di promozione sociale che supporta adulti con
        disabilità intellettiva lieve nel mondo del lavoro e nella vita sociale,
        con entusiasmo e calore umano.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/attivita" class="btn-primary text-base">
          Scopri le attività
        </a>
        <a href="/donazioni" class="btn-secondary text-base">
          Sostienici
        </a>
      </div>
    </div>
  </section>

  <!-- About snippet -->
  <section class="section">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-gioia-yellow-dark mb-4">Chi siamo</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          GIO.I.A è un'APS (Associazione di Promozione Sociale) nata con
          l'obiettivo di creare opportunità concrete per gli adulti con
          disabilità intellettiva lieve: percorsi lavorativi, laboratori
          creativi, uscite sociali e tanto altro.
        </p>
        <p class="text-gray-600 leading-relaxed mb-6">
          Crediamo che ogni persona abbia risorse preziose da esprimere e
          che il contesto giusto faccia la differenza.
        </p>
        <a href="/chi-siamo" class="btn-outline">
          Scopri la nostra storia
        </a>
      </div>
      <div class="bg-amber-50 rounded-2xl p-8 text-center">
        <p class="text-6xl mb-4" aria-hidden="true">🌱</p>
        <p class="text-xl font-bold text-gray-800 mb-2">Crescita e inclusione</p>
        <p class="text-gray-600">
          Ogni passo avanti è una vittoria condivisa, celebrata insieme
          dalla nostra comunità.
        </p>
      </div>
    </div>
  </section>

  <!-- Activities preview -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-center text-gray-900 mb-4">Le nostre attività</h2>
      <p class="text-center text-gray-600 mb-10 max-w-xl mx-auto">
        Dall'orientamento lavorativo alle uscite di gruppo: tante opportunità
        per crescere, divertirsi e stare insieme.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <ActivityCard
          title="Laboratori creativi"
          description="Attività artistiche, manuali e musicali per esprimere talenti e favorire il benessere."
          icon="🎨"
          category="ricreativa"
        />
        <ActivityCard
          title="Uscite ed eventi"
          description="Gite, cinema, sport e occasioni sociali per costruire relazioni e vivere la città."
          icon="🎉"
          category="ricreativa"
        />
      </div>
      <div class="text-center mt-10">
        <a href="/attivita" class="btn-primary">Vedi tutte le attività</a>
      </div>
    </div>
  </section>

  <!-- CTA donation -->
  <section class="bg-gioia-yellow py-16 px-4 text-white text-center">
    <div class="max-w-2xl mx-auto">
      <p class="text-4xl mb-4" aria-hidden="true">💛</p>
      <h2 class="text-white mb-4">Vuoi fare la differenza?</h2>
      <p class="text-amber-100 text-lg mb-8 leading-relaxed">
        Con il tuo supporto possiamo continuare a offrire opportunità
        preziose e costruire una comunità più inclusiva.
      </p>
      <a href="/donazioni" class="inline-block bg-white text-gioia-yellow-dark font-bold py-3 px-8 rounded-full hover:bg-amber-50 transition-colors">
        Come sostenerci
      </a>
    </div>
  </section>
</Layout>
